{
  "name": "imgtor",
  "description": "Extensible image editing tool via HTML canvas (fork of DarkroomJS)",
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "homepage": "https://github.com/ai-tonia/imgtorjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-tonia/imgtorjs.git"
  },
  "author": "Matthieu Moquet <matthieu@moquet.net> (http://moquet.net/)",
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "sass": "^1.86.0",
    "vite": "^6.2.3",
    "vitest": "^3.0.9"
  },
  "scripts": {
    "build:js": "vite build",
    "build:css": "sass lib/css/darkroom.scss build/darkroom.css --style=compressed --no-source-map",
    "build": "npm run build:js && npm run build:css && node scripts/link-demo-build.mjs",
    "dev": "vite build --watch & sass --watch lib/css/darkroom.scss:build/darkroom.css --style=expanded",
    "develop": "npm run dev",
    "preview": "vite --config vite.demo.config.js",
    "start": "npm run build && vite --config vite.demo.config.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build && vitest run"
  },
  "ignore": [
    "**/.*",
    "node_modules",
    "bower_components"
  ]
}
