{
  "name": "imgtor",
  "description": "Extensible image editing tool via HTML canvas (ImgTor fork)",
  "version": "4.1.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "homepage": "https://github.com/ai-tonia/imgtorjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-tonia/imgtorjs.git"
  },
  "bugs": {
    "url": "https://github.com/ai-tonia/imgtorjs/issues"
  },
  "keywords": [
    "canvas",
    "crop",
    "fabric",
    "image",
    "image-editor",
    "imgtor",
    "rotate"
  ],
  "author": "Matthieu Moquet <matthieu@moquet.net> (http://moquet.net/)",
  "main": "./build/imgtor.js",
  "style": "./build/imgtor.css",
  "types": "./types/imgtor.d.ts",
  "exports": {
    ".": {
      "types": "./types/imgtor.d.ts",
      "default": "./build/imgtor.js"
    },
    "./imgtor.js": "./build/imgtor.js",
    "./imgtor.css": "./build/imgtor.css",
    "./package.json": "./package.json"
  },
  "files": [
    "build/imgtor.js",
    "build/imgtor.css",
    "types/imgtor.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "RELEASING.md",
    "docs/README.md",
    "docs/PLUGIN_API.md",
    "docs/MIGRATION_CANVAS_ADAPTER.md",
    "docs/FABRIC_UPGRADE.md"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.51.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "happy-dom": "^20.0.10",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build:js": "vite build",
    "build:css": "node scripts/build-css.mjs",
    "build": "npm run build:js && npm run build:css",
    "sync:demo": "node scripts/sync-demo-build.mjs",
    "prepublishOnly": "npm run build",
    "dev": "vite build --watch & node scripts/watch-css.mjs",
    "develop": "npm run dev",
    "preview": "vite --config vite.demo.config.js",
    "start": "npm run build && npm run sync:demo && vite --config vite.demo.config.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run build && vitest run",
    "test:unit": "vitest run tests/unit tests/integration",
    "test:coverage": "npm run build && vitest run --coverage",
    "test:e2e": "playwright test",
    "audit": "npm audit",
    "pr:create": "gh pr create --repo ai-tonia/imgtorjs --base main"
  },
  "ignore": [
    "**/.*",
    "node_modules"
  ]
}
